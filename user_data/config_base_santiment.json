    "unfilledtimeout": {
        "entry": 1,
        "exit": 1
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {
            "enableRateLimit": true,
            "rateLimit": 50,
          "ccxt_async_config": {
            "enableRateLimit": true,
            "rateLimit": 50
          }
        },
        "pair_whitelist": [
            "1INCH/USDT:USDT",
            "AAVE/USDT:USDT",
            "ADA/USDT:USDT",
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "DOT/USDT:USDT",
            "LINK/USDT:USDT",
            "DOGE/USDT:USDT",
            "SOL/USDT:USDT",
            "MATIC/USDT:USDT",
            "EGLD/USDT:USDT",
            "XLM/USDT:USDT",
            "XRP/USDT:USDT",
